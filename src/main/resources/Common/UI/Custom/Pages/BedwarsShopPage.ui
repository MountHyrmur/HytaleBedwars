$C = "../Common.ui";

$C.@PageOverlay {}

@MaterialSlotSize = 46;

Group {
  Anchor: (Width: 806, Height: 480);
  LayoutMode: Top;

  TabNavigation #TopTabs {
    Anchor: (Height: 66, Left: 2, Right: 0);
    Style: $C.@TopTabsStyle;
  }

  $C.@Container {
    Anchor: (Width: 740, Height: 480, Left: 0);

    #Title {
      $C.@Title #TitleLabel {}
    }

    #Content {
      Group #ItemGrid {
        LayoutMode: LeftCenterWrap;
      }
    }
  }
}

$C.@BackButton {}